# Plantilla de variables de entorno. Copiar a .env y rellenar.
# El .env real NUNCA se versiona (está en .gitignore).

# Google Places API (New) — para prospección de negocios locales
GOOGLE_PLACES_API_KEY=tu_key_aqui

# Apify — actor Google Maps con detalles de contacto (incluye email).
# Token en Apify → Settings → Integrations. Usado por scripts/apify-places.js
APIFY_TOKEN=PEGA_TU_TOKEN_AQUI

# Airtable — base del pipeline CRM Kunda Leads (tablas: Leads / Toques de seguimiento / Métricas)
AIRTABLE_BASE_ID=app9XFFqPvRTFemz2
# (base alternativa, piloto Piura previo: app7rc27IEElVabqA)
# Personal Access Token de Airtable (scope data.records:write). Usado por airtableService.
AIRTABLE_API_KEY=PEGA_TU_TOKEN_AQUI
# Nombre/ID de la tabla destino (default "Leads" si se omite)
AIRTABLE_TABLA=Leads
